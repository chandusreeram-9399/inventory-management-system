# Copy this file to .env in the project root before running `docker-compose up`.
# NEVER commit a real .env file with production secrets.

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=inventory_db

# --- Backend ---
# Comma-separated list of origins allowed to call the API.
# Include the URL the frontend container is served on (default below)
# plus any deployed frontend URL once you go live.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080
# Products at/below this stock level are flagged as "low stock".
LOW_STOCK_THRESHOLD=10

# --- Frontend ---
# Baked into the static build at image build time (Vite resolves
# import.meta.env.VITE_* at build time, not at container runtime).
# For local docker-compose use, the backend is reachable at localhost:8000
# from the browser. For a deployed frontend, set this to your live backend URL.
VITE_API_URL=http://localhost:8000
