# Copy this file to .env for local (non-Docker) development.
# In Docker Compose, these are injected via docker-compose.yml instead.
# NEVER commit a real .env file — it is already listed in .gitignore.

# PostgreSQL connection string: postgresql://<user>:<password>@<host>:<port>/<db>
DATABASE_URL=postgresql://neondb_owner:npg_52TcDNuXnUmy@ep-young-forest-aduoz1ie-pooler.c-2.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
# Comma-separated list of allowed frontend origins (use * only for local dev)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Products at/below this stock level are flagged as "low stock" on the dashboard
LOW_STOCK_THRESHOLD=10
