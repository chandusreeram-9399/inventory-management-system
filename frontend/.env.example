# Copy to .env for local development (Vite only exposes vars prefixed VITE_)
# Points the frontend at your backend API base URL.

# Local dev (backend run via docker-compose or uvicorn directly):
VITE_API_URL=http://localhost:8000

# When deployed, set this in your hosting platform's environment settings
# to your live backend URL, e.g.:
# VITE_API_URL=https://your-backend.onrender.com
